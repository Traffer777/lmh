# Скопируйте в .env и заполните.

# База данных. Демо — SQLite. Прод — PostgreSQL (поменять provider в prisma/schema.prisma).
DATABASE_URL="file:./dev.db"

# Режим оплаты: mock (демо без ключей) | test (тестовые ключи) | live (боевые)
PAYMENT_MODE="mock"

# ЮKassa (СБП, карты). Берётся в личном кабинете: Настройки → API.
YOOKASSA_SHOP_ID=""
YOOKASSA_SECRET_KEY=""

# Т-Банк «Долями» (оплата в 4 части) — отдельный терминал, выдаёт банк при подключении сервиса.
TBANK_DOLYAMI_TERMINAL_KEY=""
TBANK_DOLYAMI_PASSWORD=""

# Доступ в админку /admin
ADMIN_LOGIN="admin"
ADMIN_PASSWORD="смените-пароль"
ADMIN_SECRET="случайная-строка-минимум-32-символа"

# URL сайта (для callback'ов оплаты)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Порог бесплатной доставки, руб.
FREE_SHIPPING_THRESHOLD="15000"

# Уведомления о заказах в Telegram (опционально)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
